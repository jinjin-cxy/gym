<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.jinjin.gymmanagementsystem.mapper.EquipmentMapper">
    <select id="selectEquipmentCount" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM equipment
    </select>

    <select id="selectEquipmentByEquipmentId" parameterType="java.lang.Integer" resultType="com.jinjin.gymmanagementsystem.pojo.Equipment">
        SELECT * FROM equipment WHERE equipment_id = #{equipmentId}
    </select>

    <select id="findAll" resultType="com.jinjin.gymmanagementsystem.pojo.Equipment">
        SELECT * FROM equipment
    </select>

    <insert id="insertEquipment" parameterType="com.jinjin.gymmanagementsystem.pojo.Equipment"
            useGeneratedKeys="true" keyProperty="equipmentId">
        INSERT INTO equipment (equipment_name, equipment_location,
        equipment_status, equipment_message)
        VALUES (#{equipmentName}, #{equipmentLocation},
        #{equipmentStatus}, #{equipmentMessage})
    </insert>

    <delete id="deleteEquipmentByEquipmentId" parameterType="java.lang.Integer">
        DELETE FROM equipment WHERE equipment_id = #{equipmentId}
    </delete>

    <update id="updateEquipmentByEquipmentId" parameterType="com.jinjin.gymmanagementsystem.pojo.Equipment">
        UPDATE equipment
        SET equipment_name = #{equipmentName},
        equipment_location = #{equipmentLocation},
        equipment_status = #{equipmentStatus},
        equipment_message = #{equipmentMessage}
        WHERE equipment_id = #{equipmentId}
    </update>
</mapper>
